# Copy this file to `.env` and adjust to your local MySQL setup.
PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=legal_marketing_dashboard

# Allowed origin for the Vite dev server (frontend).
CORS_ORIGIN=http://localhost:5173

# Monthly revenue target (Rp) used to compute "Pencapaian Target" on the dashboard.
MONTHLY_TARGET=100000000

# Auth. Generate a strong random secret for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
